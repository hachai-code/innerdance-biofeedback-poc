# --- Participant health data — never commit ---
data/**/*.csv
data/**/*.json
data/**/*.docx
data/**/*.xlsx
# Keep only the README and the pipeline sample file
!data/README.md
!data/sample/**

# --- Audio files (large — use Git LFS for large repos: git lfs track "*.mp3") ---
# sound/ folder files ARE tracked for the pipeline sample set
# *.mp3 at root level excluded; sound subfolder files are allowed
*.mp3
*.m4a
*.wav
!sound/**/*.mp3
!sound/**/*.m4a

# --- Raw source documents ---
raw/*.pdf
raw/*.docx
raw/*.doc

# --- Generated outputs ---
outputs/figures/*.png
outputs/figures/*.jpg
outputs/figures/*.svg
# HTML reports are PRIMARY OUTPUT — track them
# outputs/*.html
outputs/__pycache__/

# --- Python ---
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- MLflow ---
mlruns/
mlartifacts/

# --- Environment variables ---
.env
.env.local
.env.*.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
**/.DS_Store
Thumbs.db

# --- Supabase local ---
.supabase/
supabase/.branches/
supabase/.temp/
